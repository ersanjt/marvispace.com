# MARVISPACE — clean URLs
# @author Ersan JT <https://github.com/ersanjt>
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Legacy asset paths (pre-restructure)
  RewriteRule ^fonts\.css$ /assets/css/fonts.css [R=301,L,NC]
  RewriteRule ^styles\.css$ /assets/css/styles.css [R=301,L,NC]
  RewriteRule ^cart-ui\.css$ /assets/css/cart-ui.css [R=301,L,NC]
  RewriteRule ^checkout\.css$ /assets/css/checkout.css [R=301,L,NC]
  RewriteRule ^admin\.css$ /assets/css/admin.css [R=301,L,NC]
  RewriteRule ^page\.css$ /assets/css/page.css [R=301,L,NC]
  RewriteRule ^app\.js$ /assets/js/pages/home.js [R=301,L,NC]
  RewriteRule ^checkout\.js$ /assets/js/pages/checkout.js [R=301,L,NC]
  RewriteRule ^admin\.js$ /assets/js/pages/admin.js [R=301,L,NC]
  RewriteRule ^storage\.js$ /assets/js/core/storage.js [R=301,L,NC]
  RewriteRule ^cart-ui\.js$ /assets/js/modules/cart-ui.js [R=301,L,NC]
  RewriteRule ^products\.js$ /assets/js/data/products.js [R=301,L,NC]
  RewriteRule ^images/(.*)$ /assets/images/$1 [R=301,L,NC]

  # Redirect legacy .html URLs to clean paths (only when the browser requested .html)
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ / [R=301,L,NC]

  RewriteCond %{THE_REQUEST} \s/+checkout\.html[\s?] [NC]
  RewriteRule ^checkout\.html$ /checkout [R=301,L,NC]

  RewriteCond %{THE_REQUEST} \s/+admin\.html[\s?] [NC]
  RewriteRule ^admin\.html$ /admin [R=301,L,NC]

  RewriteCond %{THE_REQUEST} \s/+contact\.html[\s?] [NC]
  RewriteRule ^contact\.html$ /contact [R=301,L,NC]

  RewriteCond %{THE_REQUEST} \s/+terms\.html[\s?] [NC]
  RewriteRule ^terms\.html$ /terms [R=301,L,NC]

  RewriteCond %{THE_REQUEST} \s/+privacy\.html[\s?] [NC]
  RewriteRule ^privacy\.html$ /privacy [R=301,L,NC]

  RewriteCond %{THE_REQUEST} \s/+accessibility\.html[\s?] [NC]
  RewriteRule ^accessibility\.html$ /accessibility [R=301,L,NC]

  RewriteCond %{THE_REQUEST} \s/+order-status\.html[\s?] [NC]
  RewriteRule ^order-status\.html$ /order-status [R=301,L,NC]

  RewriteCond %{THE_REQUEST} \s/+order-confirmation\.html[\s?] [NC]
  RewriteRule ^order-confirmation\.html$ /order-confirmation [R=301,L,NC]

  RewriteCond %{THE_REQUEST} \s/+privacy-right-center\.html[\s?] [NC]
  RewriteRule ^privacy-right-center\.html$ /privacy-right-center [R=301,L,NC]

  # Clean URL routes (internal rewrite — no redirect)
  RewriteRule ^checkout/?$ checkout.html [L,NC]
  RewriteRule ^admin/?$ admin.html [L,NC]
  RewriteRule ^contact/?$ contact.html [L,NC]
  RewriteRule ^terms/?$ terms.html [L,NC]
  RewriteRule ^privacy/?$ privacy.html [L,NC]
  RewriteRule ^accessibility/?$ accessibility.html [L,NC]
  RewriteRule ^order-status/?$ order-status.html [L,NC]
  RewriteRule ^order-confirmation/?$ order-confirmation.html [L,NC]
  RewriteRule ^privacy-right-center/?$ privacy-right-center.html [L,NC]

  # REST API (PHP + MySQL)
  RewriteRule ^api/v1/cart/?$ api/v1/cart.php [L,QSA]
  RewriteRule ^api/v1/health/?$ api/v1/health.php [L,QSA]
  RewriteRule ^api/v1/settings/?$ api/v1/settings.php [L,QSA]
  RewriteRule ^api/v1/products/?$ api/v1/products.php [L,QSA]
  RewriteRule ^api/v1/orders/?$ api/v1/orders.php [L,QSA]
  RewriteRule ^api/v1/admin/login/?$ api/v1/admin/login.php [L,QSA]
  RewriteRule ^api/v1/admin/reset-password/?$ api/v1/admin/reset-password.php [L,QSA]
  RewriteRule ^api/v1/admin/upload/?$ api/v1/admin/upload.php [L,QSA]
  RewriteRule ^api/v1/admin/users/?$ api/v1/admin/users.php [L,QSA]
  RewriteRule ^api/v1/admin/settings/?$ api/v1/admin/settings.php [L,QSA]
  RewriteRule ^api/v1/admin/logout/?$ api/v1/admin/logout.php [L,QSA]
  RewriteRule ^api/v1/admin/me/?$ api/v1/admin/me.php [L,QSA]
  RewriteRule ^api/v1/admin/products/?$ api/v1/admin/products.php [L,QSA]
  RewriteRule ^api/v1/admin/orders/?$ api/v1/admin/orders.php [L,QSA]
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  # Do not cache HTML — always serve latest after deploy
  <FilesMatch "\.(html?)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # JS/CSS: revalidate every request (no stale admin/storefront after git pull)
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
  </FilesMatch>

  # SVG favicon + small assets that change from admin
  <FilesMatch "\.(svg)$">
    Header set Cache-Control "no-cache, must-revalidate, max-age=0"
  </FilesMatch>
</IfModule>

# Disable long-lived Expires (was 7–30 days — caused stale site)
<IfModule mod_expires.c>
  ExpiresActive Off
</IfModule>

FileETag None
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>

DirectoryIndex index.html

# ES modules + UTF-8 (keeps comments readable in browser)
<IfModule mod_mime.c>
  AddDefaultCharset UTF-8
  AddType application/javascript .js
  AddType image/svg+xml .svg
  AddType text/css .css
  AddCharset UTF-8 .js .css .html .svg
</IfModule>

# Product photos only — short cache (large files, rarely change)
# HTML/JS/CSS are no-cache via rules above
